# Leave empty to call the API on the same origin (recommended, and required for
# the single-project Vercel deployment where /api/* is served by the FastAPI
# serverless function). Only set this if you host the backend on a separate domain.
NEXT_PUBLIC_API_URL=

# Local/Docker only: where the Next.js server proxies /api/* requests.
# Defaults to http://127.0.0.1:8000 in development.
# API_PROXY_TARGET=http://127.0.0.1:8000
